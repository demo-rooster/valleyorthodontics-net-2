      "acf_fc_layout": "block_text_fh",
      "title": "Welcome to Valley Orthodontics",
      "paragraphs": [
        {
          "text": "Valley Orthodontics believes that creating a beautiful smile involves more than just straightening teeth. We look at the whole face when treating patients, emphasizing non‑extraction options to achieve balanced faces, full smiles, and healthy bites."
        },
        {
          "text": "Using high‑quality appliances and modern orthodontic technology, we design personalized treatment plans for children, teens, and adults across San Rafael, Marin, Mill Valley, Novato, and surrounding communities."
        }
      ],
